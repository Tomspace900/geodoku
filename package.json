{
  "name": "geodoku",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "volta": {
    "node": "22.19.0"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc --noEmit && vite build",
    "build:countries": "tsx scripts/prod/build-countries.ts",
    "validate:constraints": "tsx scripts/prod/validate-constraints.ts",
    "simulate:scheduling": "tsx scripts/simulate-scheduling.ts",
    "seed:grids": "npx convex run --internal seed:seedHistoricalGrids",
    "wipe:db": "npx convex run wipe:wipeAllData",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . && tsc --noEmit",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@convex-dev/rate-limiter": "^0.3.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.39.1",
    "lucide-react": "^0.460.0",
    "match-sorter": "^8.3.0",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "world-countries": "^5.1.0"
  }
}
