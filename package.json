{
  "name": "geodoku",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "volta": {
    "node": "22.19.0"
  },
  "scripts": {
    "dev": "vite --host",
    "convex:dev": "convex dev",
    "build": "tsc --noEmit && vite build",
    "build:countries": "tsx scripts/prod/build-countries.ts",
    "analyze:pool": "tsx scripts/prod/analyze-pool.ts",
    "analyze:observed": "tsx --env-file-if-exists=.env.local scripts/prod/analyze-observed-difficulty.ts",
    "simulate:scheduling": "tsx scripts/simulate-scheduling.ts",
    "export:analytics": "tsx --env-file-if-exists=.env.local scripts/export-analytics.ts",
    "dump:prod": "npx convex export --prod --path ./prod-dump.zip && npx convex import --replace-all -y ./prod-dump.zip && rm ./prod-dump.zip",
    "dump:develop": "npx convex export --preview-name develop --path ./develop-dump.zip && npx convex import --replace-all -y ./develop-dump.zip && rm ./develop-dump.zip",
    "dump:prod-to-develop": "npx convex export --prod --path ./prod-dump.zip && npx convex import --preview-name develop --replace-all -y ./prod-dump.zip && rm ./prod-dump.zip",
    "seed:grids": "npx convex run seed:seedHistoricalGrids",
    "wipe:db": "npx convex run wipe:wipeAllData",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:reset": "pnpm wipe:db && pnpm seed:grids && playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check . && tsc --noEmit",
    "format": "biome format --write .",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .husky || true"
  },
  "lint-staged": {
    "*": "biome check --write --no-errors-on-unmatched --files-ignore-unknown=true"
  },
  "dependencies": {
    "@convex-dev/rate-limiter": "^0.3.2",
    "@posthog/react": "^1.10.1",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.41.0",
    "lucide-react": "^0.460.0",
    "match-sorter": "^8.3.0",
    "posthog-js": "^1.386.1",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.1",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.61.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "happy-dom": "^20.9.0",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6",
    "world-countries": "^5.1.0"
  }
}
