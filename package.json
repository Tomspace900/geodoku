{
  "name": "geodoku",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:countries": "tsx scripts/prod/build-countries.ts",
    "analyze:grids": "tsx scripts/dev/analyze-grid-candidates.ts",
    "analyze:distribution": "tsx scripts/dev/analyze-grid-distribution.ts",
    "validate:constraints": "tsx scripts/prod/validate-constraints.ts",
    "audit:flag-colors": "tsx scripts/prod/audit-flag-color-gaps.ts",
    "audit:scoring": "tsx scripts/dev/audit-scoring-levers.ts",
    "seed:grids": "npx convex run seed:seedHistoricalGrids",
    "wipe:db": "npx convex run wipe:wipeAllData",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.17.0",
    "lucide-react": "^0.460.0",
    "match-sorter": "^6.3.4",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "vaul": "^1.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "esbuild"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "happy-dom": "^15.10.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "world-countries": "^5.1.0"
  }
}
